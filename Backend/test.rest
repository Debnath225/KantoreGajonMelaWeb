@baseUrl = http://localhost:8080
@apiUrl = {{baseUrl}}/api/v1
@adminApiKey = replace_with_strong_secret_key
@jwtToken = paste_jwt_after_login
@testEmail = rest.user@example.com
@testPassword = StrongPass123

### Health
GET {{apiUrl}}/health

### Public root
GET {{baseUrl}}/

### Signup (change email each run)
POST {{apiUrl}}/auth/signup
Content-Type: application/json

{
  "fullName": "Test User",
  "email": "{{testEmail}}",
  "password": "{{testPassword}}"
}

### Login
POST {{apiUrl}}/auth/login
Content-Type: application/json

{
  "email": "{{testEmail}}",
  "password": "{{testPassword}}"
}

### Me (Bearer token required)
GET {{apiUrl}}/auth/me
Authorization: Bearer {{jwtToken}}

### Public events
GET {{apiUrl}}/events?page=1&limit=10

### Public gallery
GET {{apiUrl}}/gallery?page=1&limit=10

### Public faqs
GET {{apiUrl}}/faqs

### Contact submit
POST {{apiUrl}}/contact
Content-Type: application/json

{
  "fullName": "Visitor Demo",
  "email": "visitor@example.com",
  "message": "Namaskar, this is a test contact message from REST suite."
}

### Ask question
POST {{apiUrl}}/questions
Content-Type: application/json

{
  "name": "FAQ User",
  "email": "faq.user@example.com",
  "question": "What time does the ritual begin on opening day?"
}

### Newsletter subscribe
POST {{apiUrl}}/newsletter/subscribe
Content-Type: application/json

{
  "email": "newsletter.user@example.com",
  "source": "rest-test"
}

### Unauthorized admin list events (expected 401)
GET {{apiUrl}}/admin/events

### Admin list events
GET {{apiUrl}}/admin/events
x-api-key: {{adminApiKey}}

### Admin create event
POST {{apiUrl}}/admin/events
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "title": "REST Test Event",
  "slug": "rest-test-event",
  "description": "Temporary test event generated by test.rest",
  "location": "Kantore Test Ground",
  "startAt": "2026-04-12T05:30:00.000Z",
  "endAt": "2026-04-12T08:30:00.000Z",
  "isPublished": true
}

### Admin update event (replace :id)
PUT {{apiUrl}}/admin/events/:id
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "title": "REST Test Event Updated",
  "slug": "rest-test-event-updated",
  "description": "Updated temporary event",
  "location": "Kantore Updated Ground",
  "startAt": "2026-04-12T06:30:00.000Z",
  "endAt": "2026-04-12T09:30:00.000Z",
  "isPublished": true
}

### Admin delete event (replace :id)
DELETE {{apiUrl}}/admin/events/:id
x-api-key: {{adminApiKey}}

### Admin create gallery item
POST {{apiUrl}}/admin/gallery
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "title": "REST Gallery Item",
  "description": "Temporary gallery item for API verification",
  "imageUrl": "https://images.unsplash.com/photo-1506744038136-46273834b3fb?auto=format&fit=crop&w=1200&q=80",
  "alt": "Temple view test image",
  "tags": ["rest", "test"],
  "isPublished": true
}

### Admin update gallery item (replace :id)
PUT {{apiUrl}}/admin/gallery/:id
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "title": "REST Gallery Item Updated",
  "description": "Updated temporary gallery item",
  "imageUrl": "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80",
  "alt": "Updated temple view image",
  "tags": ["rest", "test", "updated"],
  "isPublished": true
}

### Admin delete gallery item (replace :id)
DELETE {{apiUrl}}/admin/gallery/:id
x-api-key: {{adminApiKey}}

### Admin create faq
POST {{apiUrl}}/admin/faqs
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "question": "REST test FAQ question?",
  "answer": "This is a temporary FAQ created by test.rest execution.",
  "order": 999,
  "isPublished": true
}

### Admin update faq (replace :id)
PUT {{apiUrl}}/admin/faqs/:id
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "question": "REST test FAQ question updated?",
  "answer": "Updated FAQ entry for REST test suite.",
  "order": 1000,
  "isPublished": true
}

### Admin delete faq (replace :id)
DELETE {{apiUrl}}/admin/faqs/:id
x-api-key: {{adminApiKey}}

### Admin list inbound data
GET {{apiUrl}}/admin/contacts
x-api-key: {{adminApiKey}}

### Admin list subscribers
GET {{apiUrl}}/admin/subscribers
x-api-key: {{adminApiKey}}

### Admin list questions
GET {{apiUrl}}/admin/questions
x-api-key: {{adminApiKey}}

### Cloudinary signed upload payload
POST {{apiUrl}}/admin/media/sign-upload
Content-Type: application/json
x-api-key: {{adminApiKey}}

{
  "folder": "kantore/gallery"
}

### User media sign upload (requires user token)
POST {{apiUrl}}/media/sign-upload
Content-Type: application/json
Authorization: Bearer {{jwtToken}}

{
  "mediaType": "image"
}
